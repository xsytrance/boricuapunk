# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# turbopack / tooling
.turbo

# production
/build

# misc
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# python artifacts
__pycache__/
*.pyc

# env files (can opt-in for committing if needed)
.env*

# local secret/token notes
/telegram/*.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime archive ingestion artifacts
/data/runtime/*.json
/public/uploads/characters/*
/public/uploads/figurines/*
!/data/runtime/.gitkeep
!/public/uploads/characters/.gitkeep
!/public/uploads/figurines/.gitkeep

# local dropbox ingest workflow
/data/dropbox/incoming/*
/data/dropbox/processed/*
/data/dropbox/duplicates/*
/data/dropbox/failed/*
!/data/dropbox/incoming/.gitkeep
!/data/dropbox/processed/.gitkeep
!/data/dropbox/duplicates/.gitkeep
!/data/dropbox/failed/.gitkeep
